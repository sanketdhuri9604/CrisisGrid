rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core function checking if user has a specific role
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Admins have god-mode read/write over everything
    match /{document=**} {
      allow read, write: if request.auth != null && getRole() == 'admin';
    }

    // ─── Users Collection ───────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── SOS Requests ───────────────────────────────────────────
    // Public read: victims check their own SOS status without login (guest mode)
    match /sos_requests/{requestId} {
      allow create: if true;
      allow read: if true;  // Guest mode — victim tracks their SOS without auth
      allow update: if request.auth != null;
      allow delete: if request.auth != null && getRole() == 'admin';
    }

    // ─── Volunteers Collection ──────────────────────────────────
    match /volunteers/{volunteerId} {
      allow create: if request.auth != null && request.auth.uid == volunteerId;
      allow read: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == volunteerId || getRole() == 'admin');
      allow delete: if request.auth != null && getRole() == 'admin';
    }

    // ─── Pharmacy Resources ─────────────────────────────────────
    match /pharmacy_resources/{resourceId} {
      allow create, update: if request.auth != null && (getRole() == 'pharmacy' || getRole() == 'ngo' || getRole() == 'admin');
      allow read: if true;
      allow delete: if request.auth != null && (getRole() == 'admin' || getRole() == 'pharmacy');
    }
  }
}
