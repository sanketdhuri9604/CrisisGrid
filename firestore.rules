rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core function checking if user has a specific role documented
    function getRole() {
      return get(/databases/$(database)/documents/volunteers/$(request.auth.uid)).data.role;
    }

    // Admins have god-mode read/write over everything
    match /{document=**} {
      allow read, write: if request.auth != null && getRole() == 'admin';
    }

    // ─── SOS Requests Collection ───
    match /sos_requests/{requestId} {
      // Anyone can create an SOS (even unauthenticated users submitting emergency forms)
      allow create: if true;
      // Any authenticated user (Volunteers, Admins, Pharmacy) can read SOS requests
      allow read: if request.auth != null;
      // Only authenticated users can update (e.g., Volunteer taking assignment)
      allow update: if request.auth != null;
      // Nobody except admin can delete
      allow delete: if request.auth != null && getRole() == 'admin';
    }

    // ─── Volunteers Collection ───
    match /volunteers/{volunteerId} {
      // Anyone can create their initial volunteer signup record
      allow create: if request.auth != null && request.auth.uid == volunteerId;
      // Any authenticated user can read
      allow read: if request.auth != null;
      // Users can modify their own document (Trust scores, etc) or Admin can
      allow update: if request.auth != null && (request.auth.uid == volunteerId || getRole() == 'admin');
      // Only Admin can delete a volunteer
      allow delete: if request.auth != null && getRole() == 'admin';
    }

    // ─── Pharmacy Resources Collection ───
    match /resources/{resourceId} {
      // Pharmacy/NGO can add items
      allow create, update: if request.auth != null && (getRole() == 'pharmacy' || getRole() == 'ngo');
      // Anyone can read resources
      allow read: if true;
      // Only Admin or the creator can delete
      allow delete: if request.auth != null && (getRole() == 'admin' || getRole() == 'pharmacy');
    }
  }
}
